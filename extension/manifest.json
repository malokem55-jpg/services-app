{
  "manifest_version": 3,
  "name": "مساعد تسجيل دخول المؤسسات",
  "description": "يفتح صفحة تسجيل دخول المنصة (مقيم) ويملأ اسم المستخدم وكلمة المرور ببيانات المؤسسة المختارة من نظام الخدمات. لا يضغط زر الدخول.",
  "version": "1.0.0",
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": ["https://muqeem.sa/*", "https://*.muqeem.sa/*"],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:4173/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:4173/*",
        "https://*.up.railway.app/*"
      ],
      "js": ["content-app.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://muqeem.sa/*", "https://*.muqeem.sa/*"],
      "js": ["content-fill.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
