{
  "manifest_version": 3,
  "name": "مساعد تسجيل دخول المؤسسات",
  "description": "يفتح صفحة تسجيل دخول المنصة (مقيم أو الغرفة التجارية) ويملأ اسم المستخدم وكلمة المرور ببيانات المؤسسة المختارة من نظام الخدمات. لا يضغط زر الدخول.",
  "version": "1.2.0",
  "background": { "service_worker": "background.js" },
  "permissions": ["storage"],
  "host_permissions": [
    "https://muqeem.sa/*",
    "https://*.muqeem.sa/*",
    "https://mybusiness.chamber.sa/*",
    "https://*.chamber.sa/*",
    "https://eservices.najcci.org.sa/*",
    "https://*.najcci.org.sa/*",
    "https://eservices.ucci.org.sa/*",
    "https://*.ucci.org.sa/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:4173/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:4173/*",
        "https://*.up.railway.app/*",
        "https://kayan-sys.com/*",
        "https://www.kayan-sys.com/*"
      ],
      "js": ["content-app.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://muqeem.sa/*",
        "https://*.muqeem.sa/*",
        "https://mybusiness.chamber.sa/*",
        "https://*.chamber.sa/*",
        "https://eservices.najcci.org.sa/*",
        "https://*.najcci.org.sa/*",
        "https://eservices.ucci.org.sa/*",
        "https://*.ucci.org.sa/*"
      ],
      "js": ["content-fill.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
