generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  username  String?
  phone     String?
  password  String?
  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("users")
}

model Service {
  id        Int           @id @default(autoincrement())
  name      String?
  createdAt DateTime?     @map("created_at")
  updatedAt DateTime?     @map("updated_at")
  steps     ServiceStep[]
  clients   Client[]

  @@map("services")
}

model Organization {
  id               Int                        @id @default(autoincrement())
  name             String?
  number           String?
  expiredDate      DateTime?                  @map("expired_date") @db.Date
  createdAt        DateTime?                  @map("created_at")
  updatedAt        DateTime?                  @map("updated_at")
  clients          Client[]
  cardIssuances    CardIssuance[]
  loginCredentials OrganizationCredential[]

  @@map("organizations")
}

// منصات تسجيل الدخول الخارجية (مقيم / الغرفة التجارية):
// رابط صفحة الدخول قابل للتعديل، والتعطيل يخفي عمود المنصة من جدول المؤسسات
model LoginPlatform {
  id        Int      @id @default(autoincrement())
  key       String   @unique // muqeem | chamber
  enabled   Boolean  @default(false)
  loginUrl  String   @default("") @map("login_url") @db.VarChar(500)

  @@map("login_platforms")
}

// مدن الغرفة التجارية (الرياض/نجران/عنيزة): رابط دخول قابل للتعديل لكل مدينة.
// المؤسسة تتبع مدينة واحدة، وزر الدخول يفتح رابط مدينتها.
model ChamberCity {
  id        Int      @id @default(autoincrement())
  key       String   @unique // riyadh | najran | onaizah
  loginUrl  String   @default("") @map("login_url") @db.VarChar(500)

  @@map("chamber_cities")
}

// بيانات دخول المؤسسة على منصة خارجية — كلمة المرور مشفّرة AES-256-GCM
// (تشفير قابل للفك لأن الميزة تتطلب استرجاعها للتعبئة، وليس bcrypt)
model OrganizationCredential {
  id             Int          @id @default(autoincrement())
  organizationId Int          @map("organization_id")
  platform       String // muqeem | chamber
  username       String
  passwordEnc    String       @map("password_enc") @db.Text
  city           String?      @db.VarChar(32) // مدينة الغرفة (riyadh|najran|onaizah) — للمنصة chamber فقط
  createdAt      DateTime?    @map("created_at")
  updatedAt      DateTime?    @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, platform])
  @@map("organization_credentials")
}

model ServiceStep {
  id          Int          @id @default(autoincrement())
  name        String?
  number      String?
  order       Int?         @map("order")
  serviceId   Int?         @map("service_id")
  createdAt   DateTime?    @map("created_at")
  updatedAt   DateTime?    @map("updated_at")
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientSteps ClientStep[]

  @@map("service_steps")
}

// جهات القدوم: قائمة تُدار من صفحة الإعدادات ويُختار منها للعميل تحت الإجراء
model ArrivalPlace {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime? @map("created_at")
  updatedAt DateTime? @map("updated_at")
  clients   Client[]

  @@map("arrival_places")
}

model Client {
  id              Int                    @id @default(autoincrement())
  name            String?
  phone           String?
  passport        String?
  boardNumber     String?                @map("board_number")
  visaNumber      String?                @map("visa_number")
  iqamaNumber     String?                @map("iqama_number")
  iqamaEndDate    DateTime?              @map("iqama_end_date") @db.Date
  cardType        String?                @default("بدون") @map("card_type")
  notes           String?
  paymentType     String?                @map("payment_type")
  nextPaymentDate DateTime?              @map("next_payment_date") @db.Date
  amount          Float?
  // عميل شهري: استمرار توليد الدفعيات الشهرية حتى بعد انتهاء الإقامة
  generateMonthlyAfterIqama Boolean      @default(false) @map("generate_monthly_after_iqama")
  // تنبيه التفويض والتصديق (عميل تحت الإجراء): وجود التاريخ مع done=false = التنبيه نشط.
  // زر "تم التفويض" يعلّم done=true (التاريخ يبقى لعرض "تم التفويض" في التفاصيل)،
  // وإعادة التفعيل بتاريخ جديد تعيد done=false
  tafweedAlertDate DateTime?             @map("tafweed_alert_date") @db.Date
  tafweedDone      Boolean               @default(false) @map("tafweed_done")
  serviceId       Int?                   @map("service_id")
  organizationId  Int?                   @map("organization_id")
  lastStepId      Int?                   @map("last_step_id")
  arrivalPlaceId  Int?                   @map("arrival_place_id")
  createdAt       DateTime?              @map("created_at")
  updatedAt       DateTime?              @map("updated_at")
  service         Service?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  organization    Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  arrivalPlace    ArrivalPlace?          @relation(fields: [arrivalPlaceId], references: [id], onDelete: SetNull)
  steps           ClientStep[]
  payments        ClientPayment[]
  paymentMonthlies ClientPaymentMonthly[]
  cardIssuances   CardIssuance[]

  @@map("clients")
}

model ClientStep {
  id        Int          @id @default(autoincrement())
  stepDate  DateTime?    @map("step_date") @db.Date
  clientId  Int?         @map("client_id")
  stepId    Int?         @map("step_id")
  createdAt DateTime?    @map("created_at")
  updatedAt DateTime?    @map("updated_at")
  client    Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  step      ServiceStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("client_steps")
}

model ClientPayment {
  id              Int       @id @default(autoincrement())
  clientId        Int?      @map("client_id")
  amount          Float?
  nextPaymentDate DateTime? @map("next_payment_date") @db.Date
  isDone          Boolean?  @default(true) @map("is_done")
  lastPayment     Boolean?  @default(true) @map("last_payment")
  notes           String?
  createdAt       DateTime? @map("created_at")
  updatedAt       DateTime? @map("updated_at")
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_payments")
}

model ClientPaymentMonthly {
  id                Int       @id @default(autoincrement())
  clientId          Int?      @map("client_id")
  iqamaEndDate      DateTime? @map("iqama_end_date") @db.Date
  month             String?
  receivedDate      DateTime? @map("received_date") @db.Date
  amount            Float?
  receivedAmount    Float?    @map("received_amount")
  carriedOverAmount Float?    @map("carried_over_amount")
  carriedFromMonth  String?   @map("carried_from_month")
  status            String?
  notes             String?
  // دفعية متولدة بعد انتهاء الإقامة (خيار التوليد المستمر) — لا تمسّها مزامنة جدول الإقامة
  afterIqama        Boolean   @default(false) @map("after_iqama")
  createdAt      DateTime? @map("created_at")
  updatedAt      DateTime? @map("updated_at")
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_payment_monthlies")
}

// أرشيف ديون العملاء المحذوفين: لقطة منسوخة لحظة الحذف (سجل واحد لكل عميل)
model DeletedClientDue {
  id               Int       @id @default(autoincrement())
  clientName       String?   @map("client_name")
  phone            String?
  passport         String?
  iqamaNumber      String?   @map("iqama_number")
  serviceName      String?   @map("service_name")
  organizationName String?   @map("organization_name")
  paymentType      String?   @map("payment_type")
  totalDue         Float?    @default(0) @map("total_due")
  collectedAmount  Float?    @default(0) @map("collected_amount")
  status           String?   @default("pending") // pending | collected
  details          Json?     // عناصر الدين: دفعيات متأخرة / مبالغ مرحّلة / المتبقي السنوي
  collections      Json?     // سجل التحصيلات الجزئية بعد الحذف
  notes            String?   @db.Text
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime? @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  @@map("deleted_client_dues")
}

// سجل إصدارات كروت العمل: كل سطر إصدار يخصم مدته من رصيد المؤسسة (48 شهرًا لكل سنة هجرية).
// السطر يبقى بعد حذف العميل أو نقله (لا استرداد) — الرصيد لا يتغير إلا بتعديل/حذف الإصدار نفسه.
model CardIssuance {
  id             Int          @id @default(autoincrement())
  clientId       Int?         @map("client_id")
  clientName     String?      @map("client_name") // لقطة اسم العميل لتبقى القراءة ممكنة بعد حذفه
  organizationId Int          @map("organization_id")
  cardType       String       @map("card_type")
  months         Int // مدة الكرت بالشهور لحظة الإصدار
  hijriYear      Int          @map("hijri_year") // السنة الهجرية لتاريخ الإصدار (أم القرى)
  issuedAt       DateTime     @map("issued_at") @db.Date
  createdAt      DateTime?    @map("created_at")
  updatedAt      DateTime?    @map("updated_at")
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, hijriYear])
  @@index([clientId])
  @@map("card_issuances")
}

// علامة آخر منح كروت: زر المنح يعيد رصيد كل المؤسسات إلى 4 كروت لحظة الضغط.
// لا منح تلقائيًا مع السنة الهجرية، ولا أثر على تواريخ الإصدارات المسجلة —
// الرصيد = 48 شهرًا ناقص الإصدارات المسجلة بعد هذه العلامة.
model CardGrantSetting {
  id          Int      @id @default(autoincrement())
  lastGrantAt DateTime @map("last_grant_at")

  @@map("card_grant_settings")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}

model NotificationSetting {
  id         Int @id @default(autoincrement())
  cronHour   Int @map("cron_hour")
  cronMinute Int @map("cron_minute")

  @@map("notification_settings")
}

model UiSetting {
  id                      Int     @id @default(autoincrement())
  showBellCustomPayments  Boolean @default(true) @map("show_bell_custom_payments")
  showBellMonthlyPayments Boolean @default(true) @map("show_bell_monthly_payments")
  showBellIqamaSoon       Boolean @default(true) @map("show_bell_iqama_soon")
  showBellIqamaExpired    Boolean @default(true) @map("show_bell_iqama_expired")
  showUnderProcedurePage  Boolean @default(true) @map("show_under_procedure_page")
  showDeletedDuesPage     Boolean @default(true) @map("show_deleted_dues_page")
  showIqamaAlertsPage     Boolean @default(false) @map("show_iqama_alerts_page")
  showCustomMobileVersion Boolean @default(false) @map("show_custom_mobile_version")
  runOnMobile             Boolean @default(true) @map("run_on_mobile")

  @@map("ui_settings")
}

// تعبئة مقيم على الموبايل: مفتاح ثابت يحمله الـ Bookmarklet في Safari، وحقول
// «التسليح» تحدد آخر مؤسسة فُتحت من التطبيق المخصص ليجلبها الـ Bookmarklet مرة واحدة
model MobileFill {
  id             Int       @id @default(autoincrement())
  fillKey        String    @map("fill_key") @db.VarChar(64)
  organizationId Int?      @map("organization_id")
  platform       String?   @db.VarChar(32)
  armedAt        DateTime? @map("armed_at")

  @@map("mobile_fill")
}

// مسودة استيراد بيانات الدخول من إكسل: الصفوف المتبقية (غير المطابقة/الناقصة) تُحفظ
// مشفّرة AES-256-GCM ليُكملها المستخدم لاحقًا دون رفع الملف من جديد. سجل واحد (تطبيق بمستخدم واحد).
model CredentialImportDraft {
  id        Int       @id @default(autoincrement())
  payload   String    @db.Text // JSON الصفوف مشفّرًا
  updatedAt DateTime? @map("updated_at")

  @@map("credential_import_drafts")
}

model SentPushNotification {
  id            Int      @id @default(autoincrement())
  alertType     String   @map("alert_type")
  referenceId   Int      @map("reference_id")
  referenceDate DateTime @map("reference_date") @db.Date
  sentAt        DateTime @default(now()) @map("sent_at")

  @@unique([alertType, referenceId, referenceDate])
  @@map("sent_push_notifications")
}
